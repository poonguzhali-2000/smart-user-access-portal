spring:
  application:
    name: backend
  datasource:
    url: jdbc:postgresql://localhost:5432/mybuzz_crm
    username: postgres
    password: postgres
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true
        jdbc:
          time_zone: Asia/Kolkata 
  cloud:
    config:
      enabled: false
